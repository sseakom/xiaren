{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true,
    "types": [],
    "typeRoots": [],
    "strict": false,
    "noImplicitAny": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["miniprogram/*"]
    }
  },
  "include": [
    "miniprogram/**/*.ts",
    "miniprogram/**/*.tsx",
    "types/**/*.d.ts"
  ]
}
