{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true,
    "types": [],
    "typeRoots": [],
    "strict": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["miniprogram/*"]
    },
    "include": [
      "miniprogram/**/*.ts",
      "miniprogram/**/*.tsx"
    ]
  }
}
